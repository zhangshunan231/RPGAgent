# Ignore everything by default
*

# Allow git metadata files
!.gitignore

# Allow python agents
!python_agents/
!python_agents/**

# Allow Unity scripts only
!Assets/
!Assets/Scripts/
!Assets/Scripts/**
!Assets.meta
!Assets/Scripts.meta

# Optional: keep .vscode ignored
.vscode/

# Ignore common Unity generated folders
Library/
Temp/
Logs/
UserSettings/
