# Ignore everything by default
*

# Allow git metadata files
!.gitignore

# Allow python agents
!python_agents/
!python_agents/**

# But ignore python caches and local artifacts
python_agents/__pycache__/
python_agents/.cache/
*.pyc

# Allow Unity scripts only
!Assets/
!Assets/Scripts/
!Assets/Scripts/**
!Assets/Scripts.meta

# Optional: keep .vscode ignored
.vscode/

# Ignore common Unity generated folders
Library/
Temp/
Logs/
UserSettings/
